generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  HEAD_TEACHER
  ADMIN
  PRINCIPAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
}

enum ClassStatus {
  ACTIVE
  FULL
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum AssignmentType {
  ONLINE
  UPLOAD
  MIXED
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  GRADED
  LATE
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  GRADED
}

enum AlertType {
  ABSENTEEISM
  SCORE_DROP
  BEHAVIOR
  OTHER
}

enum AlertStatus {
  PENDING
  HANDLED
  RESOLVED
}

enum NotificationType {
  CLASS_REMINDER
  SCORE_ALERT
  SCHEDULE_CHANGE
  REFUND_REQUEST
  ASSIGNMENT_REMINDER
  EXAM_REMINDER
  WAITLIST_NOTIFICATION
  SYSTEM_MESSAGE
}

enum ScheduleChangeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  realName      String
  avatar        String?
  role          Role
  gender        Gender?
  birthDate     DateTime?
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)

  studentProfile   StudentProfile?
  teacherProfile   TeacherProfile?
  headTeacherClasses Class[] @relation("HeadTeacherClasses")
  
  notifications    Notification[]
  scheduleChanges  ScheduleChange[] @relation("Applicant")
  alertsHandled    Alert[]          @relation("AlertHandler")

  @@map("users")
}

model StudentProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  studentId        String   @unique
  age              Int?
  grade            String?
  school           String?
  parentName       String?
  parentPhone      String?
  assessmentScore  Float?
  enrollmentDate   DateTime @default(now())
  totalClasses     Int      @default(0)
  attendedClasses  Int      @default(0)
  totalAssignments Int      @default(0)
  submittedAssignments Int  @default(0)
  averageScore     Float?
  lastScore        Float?
  
  enrollments      ClassEnrollment[]
  submissions      AssignmentSubmission[]
  examSubmissions  ExamSubmission[]
  progressRecords  StudentProgress[]
  alerts           Alert[]
  waitlistEntries  Waitlist[]
  sessionAttendances SessionAttendance[]

  @@map("student_profiles")
}

model TeacherProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  teacherId      String   @unique
  bio            String?
  specialties    Json?
  yearsExperience Int?
  certification  String?
  hourlyRate     Float?
  totalClasses   Int      @default(0)
  avgSatisfaction Float?
  totalRatings   Int      @default(0)
  conversionRate Float?
  refundRate     Float?
  
  courses        Course[]
  liveSessions   LiveSession[]
  assignments    Assignment[]
  gradedSubmissions AssignmentSubmission[] @relation("Grader")
  gradedExams    ExamSubmission[] @relation("ExamGrader")
  classes        Class[]
  performances   TeacherPerformance[]

  @@map("teacher_profiles")
}

model Subject {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)
  
  courses     Course[]
  classes     Class[]

  @@map("subjects")
}

model Semester {
  id          String         @id @default(uuid())
  name        String
  code        String         @unique
  startDate   DateTime
  endDate     DateTime
  status      SemesterStatus @default(UPCOMING)
  createdAt   DateTime       @default(now())
  
  courses     Course[]
  classes     Class[]
  exams       Exam[]
  performances TeacherPerformance[]

  @@map("semesters")
}

model Course {
  id          String      @id @default(uuid())
  subjectId   String
  subject     Subject     @relation(fields: [subjectId], references: [id])
  semesterId  String?
  semester    Semester?   @relation(fields: [semesterId], references: [id])
  teacherId   String?
  teacher     TeacherProfile? @relation(fields: [teacherId], references: [id])
  name        String
  code        String      @unique
  description String?
  level       CourseLevel
  minAge      Int?
  maxAge      Int?
  totalSessions Int       @default(0)
  price       Float?
  popularity  Float       @default(0)
  createdAt   DateTime    @default(now())
  isActive    Boolean     @default(true)
  
  classes     Class[]
  assignments Assignment[]
  exams       Exam[]

  @@map("courses")
}

model Class {
  id             String      @id @default(uuid())
  courseId       String
  course         Course      @relation(fields: [courseId], references: [id])
  subjectId      String
  subject        Subject     @relation(fields: [subjectId], references: [id])
  teacherId      String?
  teacher        TeacherProfile? @relation(fields: [teacherId], references: [id])
  headTeacherId  String?
  headTeacher    User?     @relation("HeadTeacherClasses", fields: [headTeacherId], references: [id])
  semesterId     String?
  semester       Semester?   @relation(fields: [semesterId], references: [id])
  name           String
  code           String      @unique
  status         ClassStatus @default(ACTIVE)
  maxStudents    Int         @default(20)
  currentStudents Int        @default(0)
  classroom      String?
  schedule       Json?
  startDate      DateTime?
  endDate        DateTime?
  avgScore       Float?
  renewalRate    Float?
  createdAt      DateTime    @default(now())
  
  enrollments    ClassEnrollment[]
  liveSessions   LiveSession[]
  waitlist       Waitlist[]
  alerts         Alert[]
  assignments    Assignment[]
  exams          Exam[]

  @@map("classes")
}

model ClassEnrollment {
  id          String           @id @default(uuid())
  classId     String
  class       Class            @relation(fields: [classId], references: [id])
  studentId   String
  student     StudentProfile   @relation(fields: [studentId], references: [id])
  status      EnrollmentStatus @default(CONFIRMED)
  enrolledAt  DateTime         @default(now())
  droppedAt   DateTime?
  completionRate Float?
  
  @@unique([classId, studentId])
  @@map("class_enrollments")
}

model Waitlist {
  id          String         @id @default(uuid())
  classId     String
  class       Class          @relation(fields: [classId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  position    Int
  addedAt     DateTime       @default(now())
  notifiedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean        @default(true)

  @@unique([classId, studentId])
  @@map("waitlists")
}

model Classroom {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  capacity  Int
  equipment Json?
  isActive  Boolean @default(true)

  @@map("classrooms")
}

model LiveSession {
  id            String        @id @default(uuid())
  classId       String
  class         Class         @relation(fields: [classId], references: [id])
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id])
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  status        SessionStatus @default(SCHEDULED)
  streamUrl     String?
  meetingId     String?
  recordingUrl  String?
  attendanceCount Int         @default(0)
  createdAt     DateTime      @default(now())
  
  attendanceRecords SessionAttendance[]
  remindersSent   Boolean       @default(false)
  scheduleChanges ScheduleChange[]

  @@map("live_sessions")
}

model SessionAttendance {
  id          String      @id @default(uuid())
  sessionId   String
  session     LiveSession @relation(fields: [sessionId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  joinedAt    DateTime?
  leftAt      DateTime?
  duration    Int         @default(0)
  isPresent   Boolean     @default(false)
  note        String?

  @@unique([sessionId, studentId])
  @@map("session_attendances")
}

model Assignment {
  id           String         @id @default(uuid())
  courseId     String?
  course       Course?        @relation(fields: [courseId], references: [id])
  classId      String?
  class        Class?         @relation(fields: [classId], references: [id])
  teacherId    String
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])
  title        String
  description  String?
  type         AssignmentType
  totalScore   Float          @default(100)
  dueDate      DateTime
  createdAt    DateTime       @default(now())
  
  questions    AssignmentQuestion[]
  submissions  AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentQuestion {
  id           String   @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  questionText String
  questionType String
  options      Json?
  correctAnswer String?
  score        Float    @default(10)
  orderIndex   Int      @default(0)

  @@map("assignment_questions")
}

model AssignmentSubmission {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  graderId     String?
  grader       TeacherProfile? @relation("Grader", fields: [graderId], references: [id])
  content      Json?
  fileUrl      String?
  submittedAt  DateTime?
  status       SubmissionStatus @default(NOT_SUBMITTED)
  objectiveScore Float?
  subjectiveScore Float?
  totalScore   Float?
  feedback     String?
  gradedAt     DateTime?

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

model Exam {
  id          String      @id @default(uuid())
  courseId    String?
  course      Course?     @relation(fields: [courseId], references: [id])
  classId     String?
  class       Class?      @relation(fields: [classId], references: [id])
  semesterId  String?
  semester    Semester?   @relation(fields: [semesterId], references: [id])
  name        String
  description String?
  examType    String
  totalScore  Float       @default(100)
  startTime   DateTime
  endTime     DateTime
  status      ExamStatus  @default(DRAFT)
  createdAt   DateTime    @default(now())
  
  questions   ExamQuestion[]
  submissions ExamSubmission[]
  statistics  ExamStatistics?

  @@map("exams")
}

model ExamQuestion {
  id         String   @id @default(uuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id])
  questionText String
  questionType String
  options    Json?
  correctAnswer String?
  score      Float    @default(10)
  orderIndex Int      @default(0)
  correctRate Float?

  @@map("exam_questions")
}

model ExamSubmission {
  id          String         @id @default(uuid())
  examId      String
  exam        Exam           @relation(fields: [examId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  graderId    String?
  grader      TeacherProfile? @relation("ExamGrader", fields: [graderId], references: [id])
  answers     Json?
  submittedAt DateTime?
  gradedAt    DateTime?
  score       Float?
  feedback    String?

  @@unique([examId, studentId])
  @@map("exam_submissions")
}

model ExamStatistics {
  id            String  @id @default(uuid())
  examId        String  @unique
  exam          Exam    @relation(fields: [examId], references: [id])
  avgScore      Float?
  maxScore      Float?
  minScore      Float?
  passRate      Float?
  questionStats Json?
  suggestions   String?
  generatedAt   DateTime @default(now())

  @@map("exam_statistics")
}

model StudentProgress {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  subjectId   String?
  periodType  String
  periodStart DateTime
  periodEnd   DateTime
  avgScore    Float
  classCount  Int
  assignmentCount Int
  createdAt   DateTime       @default(now())

  @@map("student_progress")
}

model Alert {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  classId     String?
  class       Class?         @relation(fields: [classId], references: [id])
  type        AlertType
  title       String
  description String
  severity    String         @default("medium")
  status      AlertStatus    @default(PENDING)
  handlerId   String?
  handler     User?          @relation("AlertHandler", fields: [handlerId], references: [id])
  handlingNote String?
  handledAt   DateTime?
  createdAt   DateTime       @default(now())

  @@map("alerts")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  content    String
  data       Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@map("notifications")
}

model ScheduleChange {
  id               String              @id @default(uuid())
  sessionId        String?
  session          LiveSession?        @relation(fields: [sessionId], references: [id])
  originalClassId  String?
  newClassId       String?
  applicantId      String
  applicant        User                @relation("Applicant", fields: [applicantId], references: [id])
  originalStartTime DateTime?
  originalEndTime   DateTime?
  newStartTime     DateTime?
  newEndTime       DateTime?
  classroom        String?
  reason           String
  status           ScheduleChangeStatus @default(PENDING)
  reviewNote       String?
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())

  @@map("schedule_changes")
}

model TeacherPerformance {
  id               String   @id @default(uuid())
  teacherId        String
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
  semesterId       String?
  semester         Semester? @relation(fields: [semesterId], references: [id])
  periodType       String
  periodStart      DateTime
  periodEnd        DateTime
  classCompletionRate Float
  studentConversionRate Float?
  refundRate       Float?
  avgSatisfaction  Float?
  totalClasses     Int
  totalStudents    Int
  avgScore         Float?
  rank             Int?
  createdAt        DateTime @default(now())

  @@map("teacher_performances")
}
